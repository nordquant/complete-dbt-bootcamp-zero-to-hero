{
	"name": "dbt Zero to Hero",
	"image": "ghcr.io/nordquant/complete-dbt-bootcamp-zero-to-hero/dbt-bootcamp-devcontainer:latest",
	"forwardPorts": [5000],
	"postCreateCommand": "uv pip install -r pyproject.toml",
	"customizations": {
		"vscode": {
			"extensions": [
				"innoverio.vscode-dbt-power-user"
			],
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python3",
				"extensions.ignoreRecommendations": true,
				"settingsSync.enabled": false,
				"python.terminal.useEnvFile": false,
				"terminal.integrated.cwd": "${containerWorkspaceFolder}/airbnb",
				"files.associations": {
					"*.yaml": "jinja-yaml",
					"*.yml": "jinja-yaml",
					"*.sql": "jinja-sql",
					"*.md": "jinja-md"
				}
			}
		}
	}
}
